# Unstoppable Domains Reseller API token
# Get yours at https://unstoppabledomains.com/resellers
UNSTOPPABLEDOMAINSSDK_BEARER=your-api-token-here

# Use sandbox environment (recommended for testing)
UD_SANDBOX=true

# Server listen address (default: :8080)
# LISTEN_ADDR=:8080

# Path to JSON database file (default: ./data.json)
# DB_PATH=./data.json
